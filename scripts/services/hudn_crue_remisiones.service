[Unit]
Description=HUDN CRUE Remisiones Django App
After=network.target

[Service]
User=lg
Group=www-data

WorkingDirectory=/opt/apps/hudn_crue_remisiones_app

Environment="DJANGO_SETTINGS_MODULE=config.settings"

ExecStart=/opt/apps/hudn_crue_remisiones_app/.venv/bin/gunicorn \
    config.wsgi:application \
    --bind 127.0.0.1:8001 \
    --workers 3 \
    --timeout 120

Restart=always

[Install]
WantedBy=multi-user.target
